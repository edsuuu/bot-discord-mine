{
    "name": "discord-enxada",
    "version": "1.0.0",
    "description": "Discord bot for managing an EnxadaHost Pterodactyl server",
    "author": "edsuuu",
    "license": "ISC",
    "type": "module",
    "scripts": {
        "dev": "nodemon --watch src --ext ts --exec \"tsx --env-file=.env src/Main.ts\"",
        "build": "tsup",
        "start": "node --env-file=.env dist/Main.js",
        "pm2:start": "pm2 start ecosystem.config.cjs",
        "pm2:stop": "pm2 stop discord-enxada",
        "pm2:restart": "pm2 restart discord-enxada",
        "pm2:logs": "pm2 logs discord-enxada",
        "pm2:status": "pm2 status",
        "lint": "eslint ."
    },
    "dependencies": {
        "discord.js": "^14.16.3",
        "ws": "^8.21.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^22.0.0",
        "@types/ws": "^8.18.1",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "jiti": "^2.6.1",
        "nodemon": "^3.1.14",
        "prettier": "^3.0.0",
        "tsup": "^8.5.1",
        "tsx": "^4.22.3",
        "typescript": "^5.5.4",
        "typescript-eslint": "^8.57.2"
    }
}
